# ============================================================
#  .env — Environment Variables
#  NEVER commit this file to version control.
#  Add .env to your .gitignore immediately.
# ============================================================

# App
APP_NAME=HealthcareAPI
APP_ENV=development
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_BASE_PATH=/api

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=t12_healthcare_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# AES Encryption (min 32 chars, keep secret)
AES_KEY=cd82719f098268e305f046d7c1e388a3
AES_IV=702a0cedee7b9a91

# JWT
JWT_SECRET=e4b13c23ce79fd680f12a369d787630b2d1ebc3c2b77095af224d2bf1f56557e

# Token Expiry (seconds)
ACCESS_TOKEN_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800

# Session
SESSION_NAME=healthcare_session
SESSION_LIFETIME=900

# CORS
ALLOWED_ORIGINS=*
